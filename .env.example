# Required — app will refuse to start without this.
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Required for GitHub API calls to not be capped at 60 requests/hour shared
# across every visitor. Create a classic PAT with no scopes (public repo
# data doesn't need any scopes) at https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional — enables AI repo summaries and AI-generated founder pitches
# (Pro-only feature; free-plan users get a static template instead).
# Without it, both features fall back to static templates for everyone.
GEMINI_API_KEY=

# Required Postgres connection string. On Railway this is usually injected
# automatically when you attach a Postgres plugin.
DATABASE_URL=

# Comma-separated accounts allowed to view the global /admin/analytics dashboard
# (all-users view). Every other route is already scoped to the logged-in
# user's own data.
ADMIN_EMAILS=

# Your production domain, used in the sitemap, robots.txt, and Open Graph
# tags. Defaults to https://bashops.site if unset.
SITE_URL=https://bashops.site

# --- Stripe billing --------------------------------------------------------
# See billing.py's module docstring for the exact Stripe Dashboard setup
# steps (create Product/Price, get API keys, configure the webhook). None
# of the /billing/* routes work until STRIPE_SECRET_KEY and
# STRIPE_PRO_PRICE_ID are both set — they show a clear "not configured"
# message instead of a broken checkout in the meantime.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Displayed Pro price in the UI (defaults to 19). Changing this alone does
# NOT change what Stripe charges — that's set by whatever Price object
# STRIPE_PRO_PRICE_ID points to. Keep both in sync.
PRO_PRICE_USD=19
