# Required. App will refuse to start without this.
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Required for GitHub API calls to avoid low unauthenticated rate limits.
GITHUB_TOKEN=

# Process-local historical evidence cache. Redis can replace this backend later.
EVIDENCE_CACHE_TTL_HOURS=24
EVIDENCE_CACHE_MAX_ENTRIES=256
EVIDENCE_CACHE_STALE_HOURS=72
EVIDENCE_OPEN_PR_SAMPLE=50
EVIDENCE_CLOSED_PR_SAMPLE=100
EVIDENCE_RELEASE_SAMPLE=20
EVIDENCE_MIN_CLOSED_PR_SAMPLE=5

# Optional. Enables AI repo summaries and Pro AI-generated founder pitches.
GEMINI_API_KEY=

# Required Postgres connection string.
DATABASE_URL=

# Comma-separated accounts allowed to view global /admin/analytics.
ADMIN_EMAILS=

# Event tracking uses the application database and does not require a separate analytics key.

# Production domain used in sitemap, robots.txt, and Open Graph tags.
# HTTPS SITE_URL enables Secure session cookies. Use http://127.0.0.1:8000 locally.
SITE_URL=https://bashops.site

# Paddle Billing. Never expose PADDLE_API_KEY or PADDLE_WEBHOOK_SECRET in frontend code.
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_RADAR_MONTHLY_PRICE_ID=
PADDLE_RADAR_ANNUAL_PRICE_ID=
PADDLE_MAINTAINER_MONTHLY_PRICE_ID=
PADDLE_MAINTAINER_ANNUAL_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENV=production

# Resend email. If omitted, delivery is disabled and token-bearing links are not logged.
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=BashOps Radar

# GitHub OAuth login.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://bashops.site/auth/github/callback

# Enables the isolated, read-only BashOps Maintainer validation routes.
MAINTAINER_ENABLED=false
